# Optional convenience file. The app and Docker image read all configuration from
# the environment directly, so a .env is NOT required — you can pass these via
# `docker run -e ...`, your shell, or your own compose file. Copy to `.env` to use
# it locally (`make debug` auto-loads it; docker compose auto-loads it too).

# Home Assistant connection
HASS_IP=192.168.1.10
HASS_PORT=8123
HASS_TOKEN=your-long-lived-access-token

# Entity IDs of the sensors to display
ENTITY_TEMPERATURE=sensor.fridge_temperature
ENTITY_HUMIDITY=sensor.fridge_humidity
# Optional: leave empty and the clock fills the whole left column
ENTITY_POWER=sensor.fridge_power

# Optional: color theme, "dark" (default) or "light"
THEME=dark

# Optional: whole-page refresh interval in seconds (default 60)
PAGE_REFRESH_INTERVAL_SECONDS=60

# Optional: port the dashboard is served on; the iPad opens http://<host>:<SERVER_PORT>/ (default 6123)
SERVER_PORT=6123

# Optional: timezone used by the container clock
TZ=Europe/Rome
